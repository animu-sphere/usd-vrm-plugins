#usda 1.0
(
    defaultPrim = "Asset"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Asset" (
    kind = "component"
)
{
    def Scope "mtl"
    {
        def Scope "Mat"
        {
            def Shader "baseColorTexture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @textures/albedo.png@
            }
        }
    }
}
