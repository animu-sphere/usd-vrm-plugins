#usda 1.0
(
    """Schema-only smoke fixture: applies every Vrm*API schema and authors a
    few builtins, with no .vrm importer involved. Exercised by the bundle's
    tests.smoke/tests.roundtrip entries and tests/test_vrmschema_plugin.py."""
    defaultPrim = "Asset"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Asset"
{
    def Scope "rig"
    {
        def Scope "Humanoid" (
            prepend apiSchemas = ["VrmHumanoidAPI"]
        )
        {
            uniform token vrm:humanBones:head = "J_Bip_C_Head"
            uniform token vrm:humanBones:hips = "J_Bip_C_Hips"
            uniform token vrm:humanBones:spine = "J_Bip_C_Spine"
        }

        def Scope "Expressions"
        {
            def Scope "happy" (
                prepend apiSchemas = ["VrmExpressionAPI"]
            )
            {
                uniform bool vrm:isBinary = 0
                uniform token vrm:expressionType = "preset"
                uniform float[] vrm:morphTargetWeights = [1]
            }
        }

        def Scope "LookAt" (
            prepend apiSchemas = ["VrmLookAtAPI"]
        )
        {
            uniform token vrm:leftEye = "J_Adj_L_FaceEye"
            uniform token vrm:rightEye = "J_Adj_R_FaceEye"
            uniform token vrm:type = "bone"
        }

        def Scope "SecondaryMotion"
        {
            def Scope "spring_Hair" (
                prepend apiSchemas = ["VrmSpringBoneAPI"]
            )
            {
                uniform float[] vrm:dragForce = [0.4]
                uniform float[] vrm:stiffness = [1]
                uniform token[] vrm:joints = ["J_Sec_Hair1"]
            }

            def Scope "collider_Head" (
                prepend apiSchemas = ["VrmColliderAPI"]
            )
            {
                uniform token vrm:node = "J_Bip_C_Head"
                uniform float3 vrm:offset = (0, 0.1, 0)
                uniform float vrm:radius = 0.08
                uniform token vrm:shape = "sphere"
            }
        }

        def Scope "Constraints"
        {
            def Scope "constraint_Roll" (
                prepend apiSchemas = ["VrmConstraintAPI"]
            )
            {
                uniform token vrm:axis = "X"
                uniform token vrm:constrained = "J_Bip_L_LowerArm"
                uniform token vrm:source = "J_Bip_L_Hand"
                uniform token vrm:type = "roll"
                uniform float vrm:weight = 0.5
            }
        }
    }
}
