#usda 1.0
(
    defaultPrim = "Asset"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Asset" (
    customData = {
        dictionary vrm = {
            bool frontAxisNormalized = 0
            string meta = '''{
    "authors": ["usd-vrm-plugins"],
    "avatarPermission": "everyone",
    "licenseUrl": "https://www.apache.org/licenses/LICENSE-2.0",
    "name": "usdVrm Fixture",
    "version": "1.0"
}'''
            string rawExtension = '{"specVersion":"1.0","meta":{"name":"usdVrm Fixture","version":"1.0","authors":["usd-vrm-plugins"],"licenseUrl":"https://www.apache.org/licenses/LICENSE-2.0","avatarPermission":"everyone"},"humanoid":{"humanBones":{}}}'
            int schemaContractVersion = 1
            string sourceFormat = "VRM"
            string sourceFrontAxis = "+Z"
            string sourceVersion = "1.0"
            string specVersion = "1.0"
        }
    }
    kind = "component"
)
{
    def Scope "mtl"
    {
        def Material "Mat" (
            customData = {
                dictionary vrm = {
                    int sourceMaterialIndex = 0
                }
            }
        )
        {
            token outputs:surface.connect = </Asset/mtl/Mat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.6, 0.5)
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.7
                token outputs:surface
            }
        }

        def Material "Mat_2" (
            customData = {
                dictionary vrm = {
                    int sourceMaterialIndex = 1
                }
            }
        )
        {
            token outputs:surface.connect = </Asset/mtl/Mat_2/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.8, 0.6, 0.5)
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.7
                token outputs:surface
            }
        }
    }

    def Scope "geo"
    {
        def Mesh "Body" (
            apiSchemas = ["MaterialBindingAPI"]
            customData = {
                dictionary vrm = {
                    int sourceMeshIndex = 0
                    int sourceNodeIndex = 0
                    string sourceNodeName = "Body"
                    int sourcePrimitiveIndex = 0
                }
            }
        )
        {
            float3[] extent = [(-0.5, 0, 0), (0.5, 1, 0)]
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
            rel material:binding = </Asset/mtl/Mat>
            point3f[] points = [(-0.5, 0, 0), (0.5, 0, 0), (0, 1, 0)]
            uniform token subdivisionScheme = "none"
        }

        def Mesh "Body_2" (
            apiSchemas = ["MaterialBindingAPI"]
            customData = {
                dictionary vrm = {
                    int sourceMeshIndex = 1
                    int sourceNodeIndex = 1
                    string sourceNodeName = "Body"
                    int sourcePrimitiveIndex = 0
                }
            }
        )
        {
            float3[] extent = [(-0.5, 0, 0), (0.5, 1, 0)]
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
            rel material:binding = </Asset/mtl/Mat_2>
            point3f[] points = [(-0.5, 0, 0), (0.5, 0, 0), (0, 1, 0)]
            uniform token subdivisionScheme = "none"
        }

        def Mesh "_u9854" (
            apiSchemas = ["MaterialBindingAPI"]
            customData = {
                dictionary vrm = {
                    int sourceMeshIndex = 2
                    int sourceNodeIndex = 2
                    string sourceNodeName = "\\u9854"
                    int sourcePrimitiveIndex = 0
                }
            }
        )
        {
            float3[] extent = [(-0.5, 0, 0), (0.5, 1, 0)]
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
            rel material:binding = </Asset/mtl/Mat>
            point3f[] points = [(-0.5, 0, 0), (0.5, 0, 0), (0, 1, 0)]
            uniform token subdivisionScheme = "none"
        }

        def Mesh "Mesh_739d0383" (
            apiSchemas = ["MaterialBindingAPI"]
            customData = {
                dictionary vrm = {
                    int sourceMeshIndex = 3
                    int sourceNodeIndex = 3
                    int sourcePrimitiveIndex = 0
                }
            }
        )
        {
            float3[] extent = [(-0.5, 0, 0), (0.5, 1, 0)]
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
            rel material:binding = </Asset/mtl/Mat_2>
            point3f[] points = [(-0.5, 0, 0), (0.5, 0, 0), (0, 1, 0)]
            uniform token subdivisionScheme = "none"
        }
    }

    def Scope "rig"
    {
    }
}

