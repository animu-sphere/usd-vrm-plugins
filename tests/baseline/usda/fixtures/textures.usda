#usda 1.0
(
    defaultPrim = "Asset"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Asset" (
    customData = {
        dictionary vrm = {
            bool frontAxisNormalized = 0
            string meta = '''{
    "authors": ["usd-vrm-plugins"],
    "avatarPermission": "everyone",
    "licenseUrl": "https://www.apache.org/licenses/LICENSE-2.0",
    "name": "usdVrm Fixture",
    "version": "1.0"
}'''
            string rawExtension = '{"specVersion":"1.0","meta":{"name":"usdVrm Fixture","version":"1.0","authors":["usd-vrm-plugins"],"licenseUrl":"https://www.apache.org/licenses/LICENSE-2.0","avatarPermission":"everyone"},"humanoid":{"humanBones":{}}}'
            int schemaContractVersion = 1
            string sourceFormat = "VRM"
            string sourceFrontAxis = "+Z"
            string sourceVersion = "1.0"
            string specVersion = "1.0"
        }
    }
    kind = "component"
)
{
    def Scope "mtl"
    {
        def Material "Skin" (
            customData = {
                dictionary vrm = {
                    dictionary mtoon = {
                        string raw = '{"specVersion":"1.0","shadeColorFactor":[0.5,0.2,0.2]}'
                    }
                    int sourceMaterialIndex = 0
                }
            }
        )
        {
            token outputs:surface.connect = </Asset/mtl/Skin/Surface.outputs:surface>
            custom uniform token vrm:shaderModel = "MToon"

            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (1, 1, 1)
                color3f inputs:diffuseColor.connect = </Asset/mtl/Skin/baseColorTexture.outputs:rgb>
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:metallic = 1
                float inputs:opacity = 1
                float inputs:roughness = 1
                token outputs:surface
            }

            def Shader "stReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname = "st"
                float2 outputs:result
            }

            def Shader "baseColorTexture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @${REPO}/plugins/usdVrm/tests/fixtures/textures.vrm[images/0198c0f73fbeb889.png]@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </Asset/mtl/Skin/stReader.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "clamp"
                float outputs:a
                float outputs:b
                float outputs:g
                float outputs:r
                float3 outputs:rgb
            }
        }
    }

    def Scope "geo"
    {
        def Mesh "Body" (
            apiSchemas = ["MaterialBindingAPI"]
            customData = {
                dictionary vrm = {
                    int sourceMeshIndex = 0
                    int sourceNodeIndex = 0
                    string sourceNodeName = "Body"
                    int sourcePrimitiveIndex = 0
                }
            }
        )
        {
            float3[] extent = [(-0.5, 0, 0), (0.5, 1, 0)]
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
            rel material:binding = </Asset/mtl/Skin>
            point3f[] points = [(-0.5, 0, 0), (0.5, 0, 0), (0, 1, 0)]
            texCoord2f[] primvars:st = [(0, 1), (1, 1), (0.5, 0)] (
                interpolation = "vertex"
            )
            uniform token subdivisionScheme = "none"
        }
    }

    def Scope "rig"
    {
    }
}

