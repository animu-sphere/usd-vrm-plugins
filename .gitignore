# --- OpenStrata / build state (tool-owned, never committed) ---
/build/
**/build/
**/dist/
/.strata/
**/.strata/
CMakeUserPresets.json
strata.lock

# Built plugin libraries are staged into each bundle's lib/ by `ost plugin build`.
**/lib/

# --- Local docs & reports (kept out of version control by request) ---
# /docs is local-by-default: the ost dogfooding reports under docs/report/ost/
# must never be pushed. Committed docs are explicitly un-ignored below so a plain
# `git add docs/<file>` works (no `git add -f`); everything else under /docs stays
# local.
# Note: match /docs/* (contents), not /docs/ (the dir) — git cannot re-include a
# child of an excluded directory, so the negations below only work this way.
/docs/*
!/docs/DESIGN_POLICY.md
!/docs/ROADMAP.md
!/docs/CAPABILITY_MATRIX.md
!/docs/SUPPORTED_CONFIGURATIONS.md

# Local samples and experiments.
/scratch/

# --- CMake / MSVC generated ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
*.obj
*.pdb
*.ilk
*.exp
*.lib
*.dll

# --- Python cache ---
__pycache__/
*.pyc
*.pyo

# --- Editor / OS noise ---
.vs/
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Agent / assistant tooling (local, not shared) ---
/.claude/
